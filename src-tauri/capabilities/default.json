{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions",
  "windows": ["main"],
  "permissions": [
    "dialog:default",
    "fs:allow-stat",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/redactor-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
